# -----------------------------------------------------------------------
# Environment Configuration — Job Pipeline API
# -----------------------------------------------------------------------
# Copy this file to .env and fill in real values before running.
# -----------------------------------------------------------------------

# --- API Keys (REQUIRED) ---
TEAL_API_KEY=your-teal-api-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-api-key-here


# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Application ---
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=Job Pipeline API
APP_VERSION=0.1.0

# --- External Service URLs (override if self-hosting) ---
TEAL_BASE_URL=https://api.teal.dev/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# --- HTTP Client Tuning ---
HTTP_TIMEOUT_SECONDS=30.0
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_BASE=1.0

# --- Celery ---
CELERY_TASK_DEFAULT_QUEUE=pipeline
CELERY_TASK_ACKS_LATE=true
CELERY_WORKER_PREFETCH_MULTIPLIER=1
